<!-- Minimal Icecast config for remote-df.
     ffmpeg pushes the DF audio to the /df.ogg mount as a *source*; browsers
     connect as *listeners*. Unlike ffmpeg's one-client `-listen` HTTP server,
     Icecast fans the same stream out to many listeners and survives tab
     reloads/reconnects. Bound to loopback only; nginx proxies it at /audio. -->
<icecast>
    <limits>
        <clients>50</clients>
        <sources>2</sources>
        <queue-size>524288</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <burst-on-connect>1</burst-on-connect>
        <burst-size>65536</burst-size>
    </limits>

    <authentication>
        <!-- Loopback-only; these are not exposed publicly. -->
        <source-password>dfsource</source-password>
        <relay-password>dfrelay</relay-password>
        <admin-user>admin</admin-user>
        <admin-password>dfadmin</admin-password>
    </authentication>

    <hostname>localhost</hostname>
    <listen-socket>
        <port>8000</port>
        <bind-address>127.0.0.1</bind-address>
    </listen-socket>

    <mount type="normal">
        <mount-name>/df.ogg</mount-name>
        <public>0</public>
        <!-- Hand new listeners a burst so audio starts quickly. -->
        <burst-size>65536</burst-size>
    </mount>

    <fileserve>0</fileserve>

    <paths>
        <basedir>/usr/share/icecast2</basedir>
        <logdir>/var/log/df</logdir>
        <webroot>/usr/share/icecast2/web</webroot>
        <adminroot>/usr/share/icecast2/admin</adminroot>
        <pidfile>/tmp/icecast.pid</pidfile>
    </paths>

    <logging>
        <accesslog>icecast-access.log</accesslog>
        <errorlog>icecast-error.log</errorlog>
        <loglevel>2</loglevel>
    </logging>

    <security>
        <chroot>0</chroot>
        <!-- Icecast refuses to run as root. The container has no other user, so
             start as root and drop to the package's icecast2 user/group. start.sh
             makes the log dir writable by it. -->
        <changeowner>
            <user>icecast2</user>
            <group>icecast</group>
        </changeowner>
    </security>
</icecast>
